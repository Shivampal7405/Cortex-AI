{
  "manifest_version": 3,
  "name": "Cortex — AI Co-pilot",
  "version": "1.1.0",
  "description": "Live token tracking, model switching, and shared memory inside Claude, ChatGPT, Gemini, and Grok.",
  "permissions": ["storage", "alarms", "notifications", "tabs", "scripting", "cookies"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://x.com/*",
    "https://grok.com/*",
    "https://api.groq.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://integrate.api.nvidia.com/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+C" },
      "description": "Open Cortex"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["agents/claude/claude.content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["agents/chatgpt/chatgpt.tracker.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["agents/gemini/gemini.tracker.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://x.com/i/grok*",
        "https://x.com/grok*",
        "https://grok.com/*"
      ],
      "js": ["agents/grok/grok.tracker.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content.css",
        "agents/claude/claude.injected.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
