{
  "manifest_version": 2,
  "name": "Cortex — AI Co-pilot",
  "version": "1.1.0",
  "description": "Live token tracking, model switching, and shared memory inside Claude, ChatGPT, Gemini, and Grok.",
  "permissions": ["storage", "alarms", "notifications", "tabs", "scripting", "https://claude.ai/*", "https://chatgpt.com/*", "https://gemini.google.com/*", "https://x.com/*", "https://api.anthropic.com/*", "https://api.openai.com/*", "https://generativelanguage.googleapis.com/*"],
  "background": {
    "scripts": ["background/background.js"],
    "type": "module"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "_execute_browser_action": {
      "suggested_key": { "default": "Alt+Shift+C" },
      "description": "Open Cortex"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["agents/claude/claude.content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["agents/chatgpt/chatgpt.content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["agents/gemini/gemini.content.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://x.com/*"],
      "js": ["agents/grok/grok.content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
